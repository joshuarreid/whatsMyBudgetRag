meta {
  name: 24 Payment Method Filtered Summary
  type: http
  seq: 24
}

post {
  url: {{baseUrl}}/rag/ask
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "question": "Summarize my cash spending for this period.",
    "period": "{{period}}",
    "payment_method": "{{paymentMethod}}"
  }
}