meta {
  name: 23 Account Filtered Categories
  type: http
  seq: 23
}

post {
  url: {{baseUrl}}/rag/ask
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "question": "Which categories drove spending on this account this period?",
    "period": "{{period}}",
    "account": "{{account}}"
  }
}