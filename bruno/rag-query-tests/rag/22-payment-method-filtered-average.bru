meta {
  name: 22 Payment Method Filtered Average
  type: http
  seq: 22
}

post {
  url: {{baseUrl}}/rag/ask
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "question": "What was my average spend on card purchases this period?",
    "period": "{{period}}",
    "payment_method": "{{paymentMethod}}"
  }
}