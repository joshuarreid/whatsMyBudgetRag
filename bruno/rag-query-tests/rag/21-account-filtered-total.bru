meta {
  name: 21 Account Filtered Total
  type: http
  seq: 21
}

post {
  url: {{baseUrl}}/rag/ask
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "question": "What was my total spend on this account this period?",
    "period": "{{period}}",
    "account": "{{account}}"
  }
}