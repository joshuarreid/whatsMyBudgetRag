SPRING_BOOT_BASE_URL=http://springboot-api
HTTP_TIMEOUT_SECONDS=10
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
MYSQL_HOST=digital-ocean-cluster-do-user-123456789-0.k.db.ondigitalocean.com
MYSQL_PORT=25060
MYSQL_DATABASE=testdbo
MYSQL_USER=testAdmin
MYSQL_PASSWORD=testpassword123
# SSL mode for DigitalOcean: REQUIRED, DISABLED, etc.
MYSQL_SSLMODE=REQUIRED
# Path to CA cert if needed (optional)
MYSQL_SSL_CA=
MYSQL_CONNECT_TIMEOUT_SECONDS=10
CONVERSATION_DEFAULT_USER=default-user
CONVERSATION_HISTORY_CONTEXT_LIMIT=10
INSIGHT_HIGH_SHARE_THRESHOLD=45
INSIGHT_OUTLIER_AMOUNT_THRESHOLD=500
